{
	"info": {
		"_postman_id": "d4g-v1-collection",
		"name": "Data4Ghana API v1",
		"description": "Unified API for Data Bundles, AFA Registrations, and E-Cards.\nWebsite: https://data4ghana.com",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Data Bundles",
			"item": [
				{
					"name": "Purchase Data (MTN)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"agent_id\": \"{{agent_id}}\",\n    \"phone\": \"0241234567\",\n    \"network\": \"MTN\",\n    \"plan_gb\": 2,\n    \"plan_cost\": 10.00\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/buy-data",
							"host": ["{{baseUrl}}"],
							"path": ["api", "buy-data"]
						}
					}
				},
				{
					"name": "Purchase Data (Telecel)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"agent_id\": \"{{agent_id}}\",\n    \"phone\": \"0201234567\",\n    \"network\": \"Telecel\",\n    \"plan_gb\": 1,\n    \"plan_cost\": 5.50\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/buy-data",
							"host": ["{{baseUrl}}"],
							"path": ["api", "buy-data"]
						}
					}
				},
				{
					"name": "Purchase Data (Ishare)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"agent_id\": \"{{agent_id}}\",\n    \"phone\": \"0261234567\",\n    \"network\": \"Ishare\",\n    \"plan_gb\": 5,\n    \"plan_cost\": 22.00\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/buy-data",
							"host": ["{{baseUrl}}"],
							"path": ["api", "buy-data"]
						}
					}
				}
			]
		},
		{
			"name": "AFA Registration",
			"item": [
				{
					"name": "Register AFA (Normal)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"agent_id\": \"{{agent_id}}\",\n    \"full_name\": \"John Doe\",\n    \"phone\": \"0559623850\",\n    \"ghana_card\": \"GHA-123456789-0\",\n    \"dob\": \"1990-01-01\",\n    \"id_front_url\": \"afa/user-id/front.jpg\",\n    \"id_back_url\": \"afa/user-id/back.jpg\",\n    \"tier\": \"normal\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/register-afa",
							"host": ["{{baseUrl}}"],
							"path": ["api", "register-afa"]
						}
					}
				}
			]
		},
		{
			"name": "E-Cards",
			"item": [
				{
					"name": "Purchase WASSCE Card",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"agent_id\": \"{{agent_id}}\",\n    \"phone\": \"0241234567\",\n    \"product\": \"ecard_wassce\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/buy-ecard",
							"host": ["{{baseUrl}}"],
							"path": ["api", "buy-ecard"]
						}
					}
				},
				{
					"name": "Purchase BECE Card",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"agent_id\": \"{{agent_id}}\",\n    \"phone\": \"0241234567\",\n    \"product\": \"ecard_bece\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/buy-ecard",
							"host": ["{{baseUrl}}"],
							"path": ["api", "buy-ecard"]
						}
					}
				}
			]
		},
		{
			"name": "Webhooks",
			"item": [
				{
					"name": "Simulate Provider Callback",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"reference\": \"VTU-REF-12345\",\n    \"status\": \"completed\",\n    \"phone\": \"0241234567\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/webhook/mtn-update",
							"host": ["{{baseUrl}}"],
							"path": ["webhook", "mtn-update"]
						}
					}
				}
			]
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "https://data4ghana.com" },
		{ "key": "agent_id", "value": "your-uuid-here" }
	]
}
